{
  "name": "scrappey-wrapper",
  "version": "2.2.0",
  "description": "Official Node.js client for the Scrappey web scraping API. Render and retrieve web pages, automate browser actions, manage persistent sessions, and route through residential proxies for reliable collection of publicly available data. Ships with TypeScript types and drop-in axios/fetch adapters.",
  "main": "index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./index.js",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./axios": {
      "types": "./types/adapters/axios.d.ts",
      "import": "./axios.js",
      "require": "./axios.js",
      "default": "./axios.js"
    },
    "./fetch": {
      "types": "./types/adapters/fetch.d.ts",
      "import": "./fetch.js",
      "require": "./fetch.js",
      "default": "./fetch.js"
    }
  },
  "files": [
    "index.js",
    "axios.js",
    "fetch.js",
    "src/",
    "types/",
    "tests/"
  ],
  "scripts": {
    "test": "node tests/adapters.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pim97/scrappey.js.git"
  },
  "keywords": [
    "scrappey",
    "web-scraping",
    "scraper",
    "scraping-api",
    "web-crawler",
    "crawler",
    "browser-automation",
    "web-automation",
    "headless-browser",
    "puppeteer",
    "playwright",
    "data-extraction",
    "web-data",
    "html-parser",
    "http-client",
    "api-client",
    "rest-client",
    "proxy",
    "residential-proxy",
    "proxy-rotation",
    "session-management",
    "axios",
    "fetch",
    "typescript"
  ],
  "author": "Scrappey <support@scrappey.com> (https://scrappey.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pim97/scrappey.js/issues"
  },
  "homepage": "https://scrappey.com",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "axios": "^1.7.0"
  }
}
